---
/**
 * Head override — inject a per-section og:image / twitter:image.
 *
 * The cards are generated by `scripts/build-og.mjs` (npm run build:og) into
 * public/img/og/. We pick one by the page's top-level section (derived from the
 * URL path, which is always available), falling back to the default card. This
 * runs in addition to Starlight's default <Head> (rendered via <Default />),
 * which already emits og:title / og:description / twitter:card.
 */
import Default from '@astrojs/starlight/components/Head.astro';

const path = Astro.url.pathname.replace(/^\/+|\/+$/g, '');
const seg = path.split('/');
// `extensions/<pkg>/…` → the package; otherwise the first segment.
const key = seg[0] === 'extensions' ? seg[1] : seg[0];
const SECTIONS = ['getting-started', 'player', 'frameworks', 'bar', 'playlist', 'tracker', 'gen', 'changelog'];
const file = SECTIONS.includes(key) ? `/img/og/${key}.png` : '/img/og.png';
const og = new URL(file, Astro.site).href;
---

<Default />
<meta property="og:image" content={og} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="WaveformPlayer documentation" />
<meta name="twitter:image" content={og} />
