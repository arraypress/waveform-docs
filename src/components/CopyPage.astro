---
/**
 * CopyPage — a header dropdown that lets a reader (or their AI agent) grab the
 * current page as clean Markdown: copy it, open the .md, or hand it to Claude /
 * ChatGPT pre-filled. Rendered in the header next to the theme toggle.
 */
const route = (Astro.locals as any).starlightRoute;
const title = route?.entry?.data?.title ?? 'this page';
const path = Astro.url.pathname;
const mdPath = path === '/' ? '/index.md' : path.replace(/\/$/, '') + '.md';
const site = (Astro.site?.toString() || '').replace(/\/$/, '');
const absMd = site + mdPath;
const prompt = `Read ${absMd} — it is the "${title}" page of the @arraypress waveform documentation. Help me use it.`;
const claude = 'https://claude.ai/new?q=' + encodeURIComponent(prompt);
const chatgpt = 'https://chatgpt.com/?q=' + encodeURIComponent(prompt);
---

<div class="copy-page">
	<button class="cp-trigger" type="button" aria-haspopup="true" aria-expanded="false" data-md={mdPath}>
		<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
		<span class="cp-label">Copy page</span>
		<svg class="cp-chev" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
	</button>
	<div class="cp-menu" hidden>
		<button class="cp-item cp-copy" type="button" data-md={mdPath}>
			<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
			<span><strong>Copy page</strong><small>Markdown to clipboard</small></span>
		</button>
		<a class="cp-item" href={mdPath} target="_blank" rel="noopener">
			<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M14 2v6h6" /></svg>
			<span><strong>View as Markdown</strong><small>Open the .md file</small></span>
		</a>
		<a class="cp-item" href={claude} target="_blank" rel="noopener">
			<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v2M12 19v2M5 12H3M21 12h-2M7.5 7.5 6 6M18 18l-1.5-1.5M16.5 7.5 18 6M6 18l1.5-1.5" /><circle cx="12" cy="12" r="3.5" /></svg>
			<span><strong>Open in Claude</strong><small>Pre-filled prompt</small></span>
		</a>
		<a class="cp-item" href={chatgpt} target="_blank" rel="noopener">
			<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 3.46 6 4 4 0 0 1 0 8A4 4 0 0 1 12 22a4 4 0 0 1-3.46-6 4 4 0 0 1 0-8A4 4 0 0 1 12 2Z" /></svg>
			<span><strong>Open in ChatGPT</strong><small>Pre-filled prompt</small></span>
		</a>
	</div>
</div>

<style>
	.copy-page { position: relative; }
	.cp-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		height: 2.25rem;
		padding: 0 0.6rem;
		font-size: var(--sl-text-xs);
		font-weight: 500;
		color: var(--sl-color-gray-1);
		background: transparent;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		cursor: pointer;
		transition: border-color 0.15s, color 0.15s;
	}
	.cp-trigger:hover { color: var(--sl-color-white); border-color: var(--sl-color-gray-4); }
	.cp-chev { opacity: 0.6; }
	.cp-menu {
		position: absolute;
		right: 0;
		top: calc(100% + 0.4rem);
		z-index: 50;
		width: 16rem;
		padding: 0.3rem;
		background: var(--sl-color-bg-nav, var(--sl-color-black));
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.7rem;
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
		backdrop-filter: blur(12px);
	}
	.cp-item {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		width: 100%;
		padding: 0.45rem 0.55rem;
		border: 0;
		border-radius: 0.5rem;
		background: transparent;
		color: var(--sl-color-gray-1);
		text-align: left;
		text-decoration: none;
		cursor: pointer;
		font-size: var(--sl-text-xs);
	}
	.cp-item:hover { background: var(--sl-color-gray-6); color: var(--sl-color-white); }
	.cp-item svg { flex-shrink: 0; opacity: 0.85; }
	.cp-item span { display: flex; flex-direction: column; line-height: 1.3; }
	.cp-item small { color: var(--sl-color-gray-3); font-size: 0.72rem; }
	@media (max-width: 50rem) {
		.cp-label { display: none; }
	}
</style>

<script>
	function initCopyPage() {
		document.querySelectorAll<HTMLElement>('.copy-page:not([data-bound])').forEach((root) => {
			root.setAttribute('data-bound', '');
			const trigger = root.querySelector<HTMLButtonElement>('.cp-trigger')!;
			const menu = root.querySelector<HTMLElement>('.cp-menu')!;
			const close = () => { menu.hidden = true; trigger.setAttribute('aria-expanded', 'false'); };
			trigger.addEventListener('click', (e) => {
				e.stopPropagation();
				const open = menu.hidden;
				menu.hidden = !open;
				trigger.setAttribute('aria-expanded', String(open));
			});
			const copyBtn = root.querySelector<HTMLButtonElement>('.cp-copy');
			copyBtn?.addEventListener('click', async () => {
				const label = copyBtn.querySelector('strong');
				try {
					const res = await fetch(copyBtn.dataset.md || '');
					await navigator.clipboard.writeText(await res.text());
					if (label) { const prev = label.textContent; label.textContent = 'Copied ✓'; window.setTimeout(() => (label.textContent = prev), 1400); }
				} catch { /* clipboard blocked */ }
				close();
			});
			document.addEventListener('click', (e) => { if (!root.contains(e.target as Node)) close(); });
			document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
		});
	}
	initCopyPage();
	document.addEventListener('astro:page-load', initCopyPage);
</script>
