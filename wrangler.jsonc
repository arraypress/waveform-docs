{
  // Static-assets-only Worker: serve the Astro/Starlight `dist/` build directly.
  // Having this file stops wrangler from auto-running `astro add cloudflare`
  // (which would pull in the SSR adapter + KV/Images bindings we don't need).
  "name": "waveform-docs",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist"
  }
}
